# Environment Variables — copy this to .env and fill in your values

# ── Server ────────────────────────────────────────────────────────────────────
PORT=5000
NODE_ENV=development

# ── MongoDB ───────────────────────────────────────────────────────────────────
# Local:   mongodb://localhost:27017/merndb
# Atlas:   mongodb+srv://<user>:<password>@cluster.mongodb.net/merndb
MONGO_URI=mongodb://localhost:27017/merndb

# ── CORS ─────────────────────────────────────────────────────────────────────
# Comma-separated list of allowed frontend origins
ALLOWED_ORIGINS=http://localhost:5173

# ── Auth (add when needed) ────────────────────────────────────────────────────
# JWT_SECRET=your_super_secret_key_here
# JWT_EXPIRES_IN=7d
